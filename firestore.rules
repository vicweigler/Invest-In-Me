rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Private user portfolio data — only the owner can read/write
    match /portfolios/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    // Private user settings — only the owner can read/write
    match /settings/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    // Public leaderboard profiles — any authenticated user can read,
    // but only the matching user can write their own entry
    match /public_portfolios/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
